DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pinly?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pinly?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"
NEXT_PUBLIC_SUPABASE_URL=""
# Optional: overrides the default Esri World Imagery satellite source with MapTiler satellite-v2.
NEXT_PUBLIC_MAPTILER_API_KEY=""
BLOB_READ_WRITE_TOKEN=""
BLOB_UPLOAD_PREFIX="posts"
BLOB_ACCESS_MODE="private"
AUTH_DEBUG_RESET_LINKS="false"
MAX_UPLOAD_SIZE_MB="4"
# Optional local override. Leave unset to use the database-backed limiter.
RATE_LIMIT_DRIVER=""
ALLOW_DESTRUCTIVE_SEED=""

# Push delivery
# Optional override for the Supabase edge function endpoint used from the app server.
SUPABASE_PUSH_FUNCTION_URL=""
# Shared bearer secret between Pinly and the Supabase edge function.
SUPABASE_PUSH_WEBHOOK_SECRET=""
# Firebase Cloud Messaging HTTP v1 service account configuration for the edge function.
FCM_PROJECT_ID=""
FCM_CLIENT_EMAIL=""
FCM_PRIVATE_KEY=""
