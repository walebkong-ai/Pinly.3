NEXT_PUBLIC_MAPTILER_API_KEY=""
AUTH_DEBUG_RESET_LINKS="false"
MAX_UPLOAD_SIZE_MB="4"
# Optional local override. Leave unset to use the database-backed limiter.
RATE_LIMIT_DRIVER=""
ALLOW_DESTRUCTIVE_SEED=""

# Optional Supabase-hosted seed and repair media
PINLY_DEMO_AVATAR_URL=""
PINLY_DEMO_IMAGE_URL=""
PINLY_DEMO_VIDEO_URL=""
PINLY_DEMO_VIDEO_THUMBNAIL_URL=""
PINLY_FALLBACK_AVATAR_URL=""
PINLY_FALLBACK_IMAGE_URL=""
PINLY_FALLBACK_VIDEO_URL=""
PINLY_FALLBACK_VIDEO_THUMBNAIL_URL=""

# Push delivery
# Optional override for the Supabase edge function endpoint used from the app server.
SUPABASE_PUSH_FUNCTION_URL=""
# Shared bearer secret between Pinly and the Supabase edge function.
SUPABASE_PUSH_WEBHOOK_SECRET=""
# Firebase Cloud Messaging HTTP v1 service account configuration for the edge function.
FCM_PROJECT_ID=""
FCM_CLIENT_EMAIL=""
FCM_PRIVATE_KEY=""
