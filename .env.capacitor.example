# Capacitor Server URL
# Set this to your deployed production URL for native builds.
# For local development, use your machine's LAN IP (not localhost):
#   CAPACITOR_SERVER_URL=http://192.168.1.x:3000
#
# For production builds:
#   CAPACITOR_SERVER_URL=https://your-pinly-domain.vercel.app
# To enable native push delivery, also add platform Firebase config files:
#   android/app/google-services.json
#   ios/App/App/GoogleService-Info.plist
CAPACITOR_SERVER_URL=https://your-pinly-domain.vercel.app
